# Server configuration
FLASK_ENV=development
PORT=5000

# Database Configuration
#
# 1. For Local Run (without Docker):
# DATABASE_URL=postgresql+asyncpg://<username>:<password>@localhost:5432/<db_name>
#
# 2. For Docker Development (via docker-compose.dev.yml):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/employees_db
